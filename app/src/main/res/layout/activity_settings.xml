<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="56dp">

        <TextView
            android:id="@+id/tv_settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings"
            android:textColor="@android:color/white"
            android:textSize="36sp"
            android:fontFamily="sans-serif-thin"
            android:layout_marginBottom="56dp" />

        <!-- GENERAL Header -->
        <TextView
            android:id="@+id/tv_header_general"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/general_header"
            android:textColor="#66FFFFFF"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="24dp" />

        <!-- Language Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/tv_label_language"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/language_title"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:fontFamily="sans-serif-light" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_lang_en"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EN"
                    android:textColor="#66FFFFFF"
                    android:textSize="16sp"
                    android:padding="8dp" />

                <View
                    android:layout_width="1dp"
                    android:layout_height="16dp"
                    android:layout_gravity="center_vertical"
                    android:background="#33FFFFFF"
                    android:layout_marginHorizontal="8dp" />

                <TextView
                    android:id="@+id/btn_lang_es"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ES"
                    android:textColor="#66FFFFFF"
                    android:textSize="16sp"
                    android:padding="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Wallpaper Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/tv_label_wallpaper"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/show_system_wallpaper"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:fontFamily="sans-serif-light" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_wallpaper"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:theme="@style/ThemeOverlay.AppCompat.Dark" />
        </LinearLayout>

        <!-- Custom Wallpaper Row -->
        <LinearLayout
            android:id="@+id/btn_select_wallpaper"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?selectableItemBackground"
            android:layout_marginBottom="32dp">

            <TextView
                android:id="@+id/tv_label_select_wallpaper"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/select_wallpaper"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:fontFamily="sans-serif-light" />
        </LinearLayout>

        <!-- Hidden Apps Row -->
        <LinearLayout
            android:id="@+id/btn_hidden_apps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?selectableItemBackground"
            android:layout_marginBottom="48dp">

            <TextView
                android:id="@+id/tv_label_hidden_apps"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/hidden_apps"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:fontFamily="sans-serif-light" />
                
            <ImageView
                 android:layout_width="24dp"
                 android:layout_height="24dp"
                 android:src="@android:drawable/ic_menu_edit"
                 android:visibility="gone" /> 
            <!-- Cleaner without icon or use chevron -->
        </LinearLayout>

        <!-- DIGITAL WELLBEING Header -->
        <TextView
            android:id="@+id/tv_header_wellbeing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/digital_wellbeing"
            android:textColor="#66FFFFFF"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="24dp" />

        <!-- Usage Limit Manager Row -->
        <LinearLayout
            android:id="@+id/btn_manage_usage_limits"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?selectableItemBackground"
            android:layout_marginBottom="48dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_label_usage_limit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/daily_limit"
                    android:textColor="@android:color/white"
                    android:textSize="18sp"
                    android:fontFamily="sans-serif-light" />
                    
                <TextView
                    android:id="@+id/tv_usage_status_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Configura tiempos de uso"
                    android:textColor="#66FFFFFF"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_crop"
                android:tint="#66FFFFFF"
                android:rotation="-90" /> 
                <!-- Using generic Chevron-like icon or edit? ic_menu_crop is just a placeholder, better standard chevron right if available? 
                     I'll stick to simple text or no icon. User prefers minimalist. 
                     Just a > or nothing. 
                     Let's use a standard arrow or just layout. -->
        </LinearLayout>


        <!-- WIDGETS Header -->
        <TextView
            android:id="@+id/tv_header_widgets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/widgets_header"
            android:textColor="#66FFFFFF"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="24dp" />

        <!-- Reset Widgets Row -->
        <LinearLayout
            android:id="@+id/btn_reset_widgets"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            android:background="?selectableItemBackground"
            android:layout_marginBottom="48dp">

            <TextView
                android:id="@+id/tv_label_reset_widgets"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/delete_all_widgets"
                android:textColor="#FF5252"
                android:textSize="18sp"
                android:fontFamily="sans-serif-light" />
        </LinearLayout>


        <!-- STYLE Header -->
        <TextView
            android:id="@+id/tv_header_style"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/style_header"
            android:textColor="#66FFFFFF"
            android:textSize="12sp"
            android:letterSpacing="0.1"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/tv_label_accent_color"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/accent_color"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:fontFamily="sans-serif-light"
            android:layout_marginBottom="16dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_themes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="80dp" />

    </LinearLayout>
</ScrollView>
