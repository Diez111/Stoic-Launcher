<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="24dp">

    <!-- CLOCK & DATE -->
    <TextClock
        android:id="@+id/tc_clock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:format12Hour="hh:mm"
        android:format24Hour="HH:mm"
        android:textColor="@android:color/white"
        android:textSize="56sp"
        android:fontFamily="sans-serif-light"
        android:letterSpacing="0.02"
        android:layout_marginTop="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextClock
        android:id="@+id/tc_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:format12Hour="EEEE, d 'de' MMMM"
        android:format24Hour="EEEE, d 'de' MMMM"
        android:textColor="#B3FFFFFF"
        android:textSize="13sp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.05"
        android:textAllCaps="true"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tc_clock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- BUBBLE GRID -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_bubbles"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:overScrollMode="never"
        android:scrollbars="none"
        android:nestedScrollingEnabled="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tc_date"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_bubble" />

</androidx.constraintlayout.widget.ConstraintLayout>
